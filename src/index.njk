---
layout: layouts/base.njk
title: Vincent Teo - Projects Showcase
description: Personal portfolio showcasing my projects.
---

<!-- Projects Showcase Controls -->
<div class="mx-auto max-w-7xl px-6 pt-24 md:pt-32">
  <div class="flex flex-col items-center justify-between border-b border-slate-800/80 pb-8 md:flex-row gap-6">
    <div class="text-center md:text-left">
      <h1 class="text-3xl font-extrabold tracking-tight text-white font-sans">
        Projects Showcase
      </h1>
    </div>
    
    <!-- Filter Tabs -->
    <div class="flex flex-wrap items-center justify-center gap-2 p-1.5 bg-slate-900/60 border-2 border-slate-800/80 rounded-3xl backdrop-blur-sm shadow-inner">
      <button id="filter-btn-all" class="playful-btn px-5 py-2 text-xs font-bold rounded-2xl transition-all duration-300 cursor-pointer bg-fuchsia-500 text-white shadow-lg shadow-fuchsia-500/30">
        All Showcase
      </button>
      <button id="filter-btn-software" class="playful-btn px-5 py-2 text-xs font-bold rounded-2xl transition-all duration-300 cursor-pointer text-slate-400 hover:text-white hover:bg-slate-800/40">
        Open Source
      </button>
      <button id="filter-btn-games" class="playful-btn px-5 py-2 text-xs font-bold rounded-2xl transition-all duration-300 cursor-pointer text-slate-400 hover:text-white hover:bg-slate-800/40">
        Games
      </button>
    </div>
  </div>
</div>

<!-- Projects Overview -->
<div class="mx-auto max-w-7xl px-6 py-20 space-y-32">
  
  <!-- SOFTWARE SECTION -->
  <section id="software" class="project-section relative scroll-mt-24" data-category="software">
    <!-- Ambient section light -->
    <div class="absolute -top-20 -left-20 w-80 h-80 bg-pink-500/10 rounded-full blur-[100px] pointer-events-none -z-10"></div>
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
      <div>
        <h2 class="text-3xl font-extrabold text-pink-400 tracking-tight sm:text-4xl">Open Source Software</h2>
      </div>
      <span class="text-xs font-semibold text-slate-500 border border-slate-900 rounded-lg bg-slate-950 px-3 py-1">
        {{ projects.software.length }} Projects
      </span>
    </div>

    <!-- Software Grid -->
    <div class="grid gap-8 md:grid-cols-2">
      {% for item in projects.software %}
      <article class="glow-card glow-card-software flex flex-col justify-between overflow-hidden rounded-3xl bg-slate-900/40 border-2 border-slate-800/80 backdrop-blur-sm group cursor-pointer">
        <div>
          <!-- Card Image -->
          <div class="relative overflow-hidden aspect-[16/10] bg-slate-950">
            <img src="{{ item.image }}" alt="{{ item.title }}" class="h-full w-full object-cover object-center group-hover:scale-[1.03] transition-transform duration-500 ease-out">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0b0f19] via-transparent to-transparent opacity-90"></div>
            {% if item.ribbon %}
            <div class="absolute top-4 right-4 z-20">
              <span class="inline-flex items-center rounded-xl bg-pink-500/90 px-3 py-1.5 text-[10px] font-black uppercase tracking-wider text-white border border-pink-400/50 shadow-lg shadow-pink-500/30 backdrop-blur-sm">
                {{ item.ribbon }}
              </span>
            </div>
            {% endif %}
          </div>
          
          <!-- Card Details -->
          <div class="p-6">
            <h3 class="text-xl font-bold text-white group-hover:text-violet-400 transition-colors duration-200">
              {% set targetUrl = item.demo | default(item.github, true) %}
              {% set isExternal = targetUrl.slice(0, 4) == 'http' %}
              <a href="{{ targetUrl }}" {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %} class="focus:outline-none">
                <span class="absolute inset-0" aria-hidden="true"></span>
                {{ item.title }}
              </a>
            </h3>
            <p class="mt-3 text-sm text-slate-400 leading-relaxed font-medium">
              {{ item.description }}
            </p>
            
            <!-- Tags -->
            <div class="mt-4 flex flex-wrap gap-2">
              {% for tag in item.tags %}
              <span class="inline-flex items-center rounded-full bg-pink-500/15 px-3 py-1 text-xs font-bold text-pink-300 border border-pink-500/30">
                {{ tag }}
              </span>
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- Links -->
        <div class="p-6 pt-0 flex items-center gap-4">
          {% if item.github %}
          <a href="{{ item.github }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-300 hover:text-white transition-colors duration-200 relative z-10">
            <svg class="h-4.5 w-4.5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.164 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
            </svg>
            GitHub
          </a>
          {% endif %}
          {% if item.demo %}
          {% set isDemoExternal = item.demo.slice(0, 4) == 'http' %}
          <a href="{{ item.demo }}" {% if isDemoExternal %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex items-center gap-1 text-xs font-bold text-pink-400 hover:text-pink-300 transition-colors duration-200 ml-auto relative z-10">
            {{ item.demoLabel | default("Live Project", true) }}
            <svg class="h-3 w-3 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </section>

  <!-- GAMES SECTION -->
  <section id="games" class="project-section relative scroll-mt-24" data-category="games">
    <!-- Ambient section light -->
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-lime-500/10 rounded-full blur-[100px] pointer-events-none -z-10"></div>
    
    <div class="flex flex-col md:flex-row md:items-end justify-between mb-12 gap-4">
      <div>
        <h2 class="text-3xl font-extrabold text-lime-400 tracking-tight sm:text-4xl">Games</h2>
      </div>
      <span class="text-xs font-semibold text-slate-500 border border-slate-900 rounded-lg bg-slate-950 px-3 py-1">
        {{ projects.games.length }} Projects
      </span>
    </div>

    <!-- Games Grid -->
    <div class="grid gap-8 md:grid-cols-2">
      {% for item in projects.games %}
      <article class="glow-card glow-card-games flex flex-col justify-between overflow-hidden rounded-3xl bg-slate-900/40 border-2 border-slate-800/80 backdrop-blur-sm group cursor-pointer">
        <div>
          <!-- Card Image -->
          <div class="relative overflow-hidden aspect-[16/10] bg-slate-950">
            <img src="{{ item.image }}" alt="{{ item.title }}" class="h-full w-full object-cover object-center group-hover:scale-[1.03] transition-transform duration-500 ease-out">
            <div class="absolute inset-0 bg-gradient-to-t from-[#0b0f19] via-transparent to-transparent opacity-90"></div>
            {% if item.ribbon %}
            <div class="absolute top-4 right-4 z-20">
              <span class="inline-flex items-center rounded-xl bg-pink-500/90 px-3 py-1.5 text-[10px] font-black uppercase tracking-wider text-white border border-pink-400/50 shadow-lg shadow-pink-500/30 backdrop-blur-sm">
                {{ item.ribbon }}
              </span>
            </div>
            {% endif %}
          </div>
          
          <!-- Card Details -->
          <div class="p-6">
            <h3 class="text-xl font-bold text-white group-hover:text-emerald-400 transition-colors duration-200">
              {% set targetUrl = item.demo | default(item.github, true) %}
              {% set isExternal = targetUrl.slice(0, 4) == 'http' %}
              <a href="{{ targetUrl }}" {% if isExternal %}target="_blank" rel="noopener noreferrer"{% endif %} class="focus:outline-none">
                <span class="absolute inset-0" aria-hidden="true"></span>
                {{ item.title }}
              </a>
            </h3>
            <p class="mt-3 text-sm text-slate-400 leading-relaxed font-medium">
              {{ item.description }}
            </p>
            
            <!-- Tags -->
            <div class="mt-4 flex flex-wrap gap-2">
              {% for tag in item.tags %}
              <span class="inline-flex items-center rounded-full bg-lime-500/15 px-3 py-1 text-xs font-bold text-lime-300 border border-lime-500/30">
                {{ tag }}
              </span>
              {% endfor %}
            </div>
          </div>
        </div>

        <!-- Links -->
        <div class="p-6 pt-0 flex items-center gap-4">
          {% if item.github %}
          <a href="{{ item.github }}" target="_blank" rel="noopener noreferrer" class="inline-flex items-center gap-1.5 text-xs font-bold text-slate-300 hover:text-white transition-colors duration-200 relative z-10">
            <svg class="h-4.5 w-4.5 fill-current" viewBox="0 0 24 24" aria-hidden="true">
              <path fill-rule="evenodd" d="M12 2C6.477 2 2 6.477 2 12c0 4.42 2.865 8.166 6.839 9.489.5.092.682-.217.682-.482 0-.237-.008-.866-.013-1.7-2.782.603-3.369-1.34-3.369-1.34-.454-1.156-1.11-1.464-1.11-1.464-.908-.62.069-.608.069-.608 1.003.07 1.531 1.032 1.531 1.032.892 1.53 2.341 1.088 2.91.832.092-.647.35-1.088.636-1.338-2.22-.253-4.555-1.11-4.555-4.943 0-1.091.39-1.984 1.029-2.683-.103-.253-.446-1.27.098-2.647 0 0 .84-.269 2.75 1.025A9.564 9.564 0 0112 6.844c.85.004 1.705.115 2.504.337 1.909-1.294 2.747-1.025 2.747-1.025.546 1.377.203 2.394.1 2.647.64.699 1.028 1.592 1.028 2.683 0 3.842-2.339 4.687-4.566 4.935.359.309.678.919.678 1.852 0 1.336-.012 2.415-.012 2.743 0 .267.18.579.688.481C19.138 20.164 22 16.418 22 12c0-5.523-4.477-10-10-10z" clip-rule="evenodd" />
            </svg>
            GitHub
          </a>
          {% endif %}
          {% if item.demo %}
          {% set isDemoExternal = item.demo.slice(0, 4) == 'http' %}
          <a href="{{ item.demo }}" {% if isDemoExternal %}target="_blank" rel="noopener noreferrer"{% endif %} class="inline-flex items-center gap-1 text-xs font-bold text-lime-400 hover:text-lime-300 transition-colors duration-200 ml-auto relative z-10">
            {{ item.demoLabel | default("Play Game", true) }}
            <svg class="h-3 w-3 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 6H5.25A2.25 2.25 0 003 8.25v10.5A2.25 2.25 0 005.25 21h10.5A2.25 2.25 0 0018 18.75V10.5m-10.5 6L21 3m0 0h-5.25M21 3v5.25" />
            </svg>
          </a>
          {% endif %}
        </div>
      </article>
      {% endfor %}
    </div>
  </section>


</div>

<!-- Hero / About Section (Moved to Bottom) -->
<section id="about" class="relative overflow-hidden py-24 md:py-32 border-t border-slate-900/60 bg-slate-950/30">
  <!-- Glowing decorative spheres -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-violet-600/10 rounded-full blur-[140px] pointer-events-none -z-10 animate-pulse"></div>
  <div class="absolute top-1/4 left-1/3 w-[300px] h-[300px] bg-cyan-500/10 rounded-full blur-[100px] pointer-events-none -z-10"></div>

  <div class="mx-auto max-w-5xl px-6 flex flex-col md:flex-row items-center gap-12">
    <!-- Left Column: Profile Photo -->
    <div class="w-48 h-48 md:w-60 md:h-60 flex-shrink-0 relative group">
      <!-- Glow background border -->
      <div class="absolute -inset-1 rounded-3xl bg-gradient-to-r from-pink-500 via-fuchsia-500 to-cyan-400 opacity-75 blur-md group-hover:opacity-100 transition duration-500"></div>
      <!-- Image frame -->
      <div class="relative w-full h-full rounded-3xl overflow-hidden border-4 border-slate-900 bg-slate-900 transition-transform duration-300 group-hover:scale-[1.04] group-hover:rotate-2">
        <img src="/assets/images/profile.jpg" alt="Vincent Teo Profile Photo" class="w-full h-full object-cover object-center">
      </div>
    </div>
    
    <!-- Right Column: Text Content -->
    <div class="flex-1 text-center md:text-left">
      <h2 class="text-4xl font-extrabold tracking-tight text-white sm:text-5xl font-sans leading-none">
        Hi, I'm Vincent.
        <span class="block mt-2 bg-gradient-to-r from-pink-500 via-amber-300 to-cyan-400 bg-clip-text text-transparent">
          Welcome to my digital space.
        </span>
      </h2>
      <p class="mt-6 text-lg leading-relaxed text-slate-400 max-w-2xl font-medium">
        Here, you'll find a showcase of my projects.
      </p>
      <div class="mt-8 flex flex-wrap items-center justify-center md:justify-start gap-4">
