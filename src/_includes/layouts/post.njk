---
layout: layouts/base.njk
---
<div class="mx-auto max-w-7xl px-6 py-20 md:py-28 flex-grow">
  <!-- Back button -->
  <div class="mb-10">
    <a href="/blog/" class="playful-btn inline-flex items-center gap-2 rounded-2xl bg-slate-900/60 border border-slate-800/80 hover:bg-slate-800/60 px-4 py-2 text-xs font-bold text-slate-300 hover:text-white transition-all duration-200 relative z-10">
      <svg class="h-4 w-4 stroke-current" fill="none" viewBox="0 0 24 24" stroke-width="2.5" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18" />
      </svg>
      Back to Blog
    </a>
  </div>

  <article class="relative overflow-hidden rounded-3xl bg-slate-900/40 border-2 border-slate-800/80 backdrop-blur-sm p-8 md:p-12">
    <!-- Ambient ambient post light -->
    <div class="absolute -top-20 -right-20 w-80 h-80 bg-violet-600/10 rounded-full blur-[100px] pointer-events-none -z-10 animate-pulse"></div>

    <header class="border-b border-slate-800/80 pb-8 mb-8">
      <time class="text-xs font-bold text-slate-500 tracking-wider uppercase block mb-3">
        {{ date | postDate }}
      </time>
      <h1 class="text-3xl font-extrabold text-white tracking-tight sm:text-4xl md:text-5xl font-sans">
        {{ title }}
      </h1>
      
      <!-- Tags list -->
      <div class="mt-6 flex flex-wrap gap-2">
        {% for tag in tags %}
          {% if tag != "posts" %}
          <span class="inline-flex items-center rounded-full bg-fuchsia-500/15 px-3 py-1 text-xs font-bold text-fuchsia-300 border border-fuchsia-500/30">
            {{ tag }}
          </span>
          {% endif %}
        {% endfor %}
      </div>
    </header>

    <!-- Post Content -->
    <div class="blog-content prose prose-invert max-w-none text-slate-300 leading-relaxed font-medium">
      {{ content | safe }}
    </div>
  </article>
</div>
