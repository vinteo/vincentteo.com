---
layout: layouts/base.njk
title: Vincent Teo - Journal
description: Personal writings, thoughts, and technical deep-dives.
permalink: /blog/
---

<!-- Blog Showcase Controls -->
<div class="mx-auto max-w-7xl px-6 pt-24 md:pt-32">
  <div class="border-b border-slate-800/80 pb-8 flex flex-col items-center md:items-start text-center md:text-left gap-4">
    <h1 class="text-4xl font-extrabold tracking-tight text-white font-sans">
      Digital Journal
    </h1>
  </div>
</div>

<!-- Blog Posts List -->
<div class="mx-auto max-w-7xl px-6 py-16 flex-grow">
  <div class="space-y-8">
    {% if collections.posts.length > 0 %}
      {% for post in collections.posts | reverse %}
      <article class="glow-card glow-card-blog relative flex flex-col justify-between overflow-hidden rounded-3xl bg-slate-900/40 border-2 border-slate-800/80 backdrop-blur-sm p-6 md:p-8 cursor-pointer group">
        <div>
          <time class="text-xs font-bold text-slate-500 tracking-wider uppercase block mb-3">
            {{ post.date | postDate }}
          </time>
          
          <h2 class="text-2xl font-extrabold text-white group-hover:text-fuchsia-400 transition-colors duration-200">
            <a href="{{ post.url }}" class="focus:outline-none">
              <span class="absolute inset-0" aria-hidden="true"></span>
              {{ post.data.title }}
            </a>
          </h2>
          
          <p class="mt-3 text-sm text-slate-400 leading-relaxed font-medium">
            {{ post.data.description }}
          </p>
          
          <!-- Tags -->
          <div class="mt-5 flex flex-wrap gap-2">
            {% for tag in post.data.tags %}
              {% if tag != "posts" %}
              <span class="inline-flex items-center rounded-full bg-fuchsia-500/15 px-3 py-1 text-xs font-bold text-fuchsia-300 border border-fuchsia-500/30">
                {{ tag }}
              </span>
              {% endif %}
            {% endfor %}
          </div>
        </div>
      </article>
      {% endfor %}
    {% else %}
      <div class="text-center py-20 bg-slate-900/20 rounded-3xl border border-slate-800/80 p-8">
        <p class="text-slate-400 font-medium">No posts written yet. Check back soon!</p>
      </div>
    {% endif %}
  </div>
</div>
